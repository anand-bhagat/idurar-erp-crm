# =============================================================================
# IDURAR ERP/CRM — Environment Configuration
# =============================================================================

# Database
DATABASE=mongodb://localhost:27017

# JWT
JWT_SECRET=your_private_jwt_secret_key

# Server
NODE_ENV=development
PUBLIC_SERVER_FILE=http://localhost:8888/

# =============================================================================
# Agent LLM Configuration
# =============================================================================

# Provider: 'openai-compatible' or 'anthropic'
AGENT_LLM_PROVIDER=openai-compatible

# API Key (required)
AGENT_LLM_API_KEY=your-api-key

# --- DeepInfra (default) ---
# AGENT_LLM_BASE_URL=https://api.deepinfra.com/v1/openai
# AGENT_LLM_MODEL=zhipu-ai/glm-4.7-flash

# --- OpenAI ---
# AGENT_LLM_PROVIDER=openai-compatible
# AGENT_LLM_BASE_URL=https://api.openai.com/v1
# AGENT_LLM_MODEL=gpt-4o-mini

# --- Groq ---
# AGENT_LLM_PROVIDER=openai-compatible
# AGENT_LLM_BASE_URL=https://api.groq.com/openai/v1
# AGENT_LLM_MODEL=llama-3.3-70b-versatile

# --- Anthropic (Claude) ---
# AGENT_LLM_PROVIDER=anthropic
# AGENT_LLM_MODEL=claude-sonnet-4-20250514

# --- OpenRouter ---
# AGENT_LLM_PROVIDER=openai-compatible
# AGENT_LLM_BASE_URL=https://openrouter.ai/api/v1
# AGENT_LLM_MODEL=zhipu-ai/glm-4.7

# --- Ollama (local) ---
# AGENT_LLM_PROVIDER=openai-compatible
# AGENT_LLM_BASE_URL=http://localhost:11434/v1
# AGENT_LLM_MODEL=llama3.3

# LLM Settings
AGENT_LLM_MAX_TOKENS=4096
AGENT_LLM_TEMPERATURE=0
AGENT_LLM_STREAMING=true
AGENT_LLM_TIMEOUT=30000
AGENT_LLM_MAX_RETRIES=2
AGENT_MAX_ITERATIONS=10

# Cost Tracking
AGENT_COST_TRACKING=true

# Token Budget
AGENT_TOKEN_BUDGET=100000

# =============================================================================
# Agent Tool Routing
# =============================================================================
AGENT_ROUTING_ENABLED=false
AGENT_ROUTING_THRESHOLD=30
AGENT_CORE_CATEGORIES=navigation
AGENT_ROUTING_CACHE_MESSAGES=5

# =============================================================================
# Agent Observability
# =============================================================================
AGENT_LOG_LEVEL=info
AGENT_TRACE_SAMPLING=1.0

# =============================================================================
# Agent Guardrails
# =============================================================================
AGENT_CIRCUIT_BREAKER_ENABLED=true
AGENT_CIRCUIT_BREAKER_THRESHOLD=5
AGENT_SANITIZATION_ENABLED=true
AGENT_INJECTION_DETECTION_ENABLED=true
AGENT_INJECTION_DETECTION_MODE=flag

# Rate Limiting
AGENT_RATE_LIMIT_WINDOW=60000
AGENT_RATE_LIMIT_MAX=20
AGENT_GUARDRAIL_RATE_LIMIT_ENABLED=true
